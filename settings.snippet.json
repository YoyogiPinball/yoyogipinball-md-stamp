{
  "_comment": "Merge this into ~/.claude/settings.json. Use an absolute path to the wrapper.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/absolute/path/to/yoyogipinball-md-stamp/hooks/claude-posttooluse.sh"
          }
        ]
      }
    ]
  }
}
